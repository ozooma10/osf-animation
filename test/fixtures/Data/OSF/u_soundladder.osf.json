{
  // Sound-ladder sugar: a `sound` OBJECT (shared defaults + `marks`) expands to one SoundEntry per
  // mark, appending each mark's tag(s) to the base `spec`. Stage 0 = ARRAY form (all mark shapes),
  // stage 1 = GROUPED form (keyed by tag -> positions).
  "schema": 1,
  "id": "osf.u.soundladder",
  "name": "Sound Ladder",
  "roles": [ { "name": "bottom" } ],
  "stages": [
    {
      "loops": 1,
      "clips": ["OSF/Anim/x.glb"],
      "sound": {
        "role": "bottom",
        "repeat": "loop",
        "spec": "$seduce,{gender},moan",
        "marks": [
          [0.1, "low"],
          [0.5, "loud", "wet"],
          0.9,
          { "at": 0.95, "tags": "climax", "repeat": "none", "role": "top" }
        ]
      }
    },
    {
      "loops": 1,
      "clips": ["OSF/Anim/y.glb"],
      "sound": {
        "role": "bottom",
        "repeat": "loop",
        "spec": "$seduce,{gender},moan",
        "marks": { "loud": [0.8], "med": [0.2, 0.6] }
      }
    }
  ]
}
