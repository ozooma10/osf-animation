{
  "schema": 1,
  "id": "osf.scene.basic",
  "name": "Basic",
  "tags": ["pair", "scenetag"],
  "roles": [
    { "name": "a", "gender": "male" },
    { "name": "b", "gender": "female" }
  ],
  "entry": "intro",
  "linearStages": ["intro", "loop"],
  "nodes": [
    {
      "id": "intro",
      "anim": "osf.test.pair",
      "loop": { "mode": "once" },
      "edges": [ { "to": "loop", "when": "end" } ],
      "tracks": {
        "cue": [ { "id": "beat", "at": 0.25 } ],
        "action": [
          { "type": "osf.fade.out", "at": "enter" },
          { "type": "osf.control.lock", "role": "a", "at": "enter" }
        ],
        "sound": [ { "sound": "OSF\\Sounds\\beat.wav", "at": 0.5 } ],
        "camera": [ { "state": "thirdperson_hold", "at": "enter" } ]
      }
    },
    {
      "id": "loop",
      "anim": "osf.test.pair",
      "loop": { "mode": "hold" },
      "loopForever": true
    }
  ]
}
