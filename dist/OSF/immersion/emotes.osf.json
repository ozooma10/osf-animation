{
  "schema": 1,
  "name": "OSF Immersion — Emotes",
  // Solo self-terminating flourishes for the emote wheel (enumerated by tag prefix
  // "player.emote."). Each scene's `name` is the wheel slice label. Linear one-stage
  // form: `loops:0` holds the pose, `timer` ends it, and every linear stage gets a
  // free default advance edge so Space skips early. The same scenes play on a
  // crosshair NPC target (anonymous role, no gender filter).
  "clipRoot": "meshes/actors/human/animations",
  "stripActors": false,
  "lockPlayer": false, // short flourishes — leave the player's controls alone
  "camera": "none",    // never touch the camera for an emote
  // No `roles` block: each scene infers one anonymous slot from its single clip —
  // the player when launched solo, or the crosshair NPC when the wheel targets one.
  // No weapon sheathe either (see the wave scene's note): emotes never touch weapon
  // state, so the third-person camera framing stays exactly as the player had it.
  "scenes": [
    {
      "id": "immersion/emote/wave",
      "name": "Wave",
      "tags": [ "player.emote.wave", "immersion" ],
      "stages": [
        {
          "timer": 4, // TUNE
          "loops": 0,
          // NO osf.weapon.sheathe here (dropped 2026-07-13): the sheathe/re-draw pair flips
          // the engine's armed/unarmed third-person camera framing — worst on an unarmed
          // player, who got a spontaneous weapon DRAW (and the armed camera) on emote end
          // because the ledger re-draw is unconditional. Emotes must leave the camera
          // exactly as it was; a drawn weapon simply stays in hand during the flourish.
          // Revisit if a verified weapon-drawn state read lands (then sheathe conditionally).
          "clips": [ { "file": "common/wave_pose.af", "sec": 0.033 } ]
        }
      ]
    },
    {
      "id": "immersion/emote/whatsup",
      "name": "What's up?",
      "tags": [ "player.emote.whatsup", "immersion" ],
      "stages": [
        {
          "timer": 4, // TUNE
          "loops": 0,
          "clips": [ { "file": "common/whatsup_pose.af", "sec": 0.033 } ]
        }
      ]
    },
    {
      "id": "immersion/emote/handsonhips",
      "name": "Hands on hips",
      "tags": [ "player.emote.handsonhips", "immersion" ],
      "stages": [
        {
          "timer": 5, // TUNE
          "loops": 0,
          "clips": [ { "file": "common/handsonhips_pose.af", "sec": 0.033 } ]
        }
      ]
    },
    {
      "id": "immersion/emote/armscrossed",
      "name": "Arms crossed",
      "tags": [ "player.emote.armscrossed", "immersion" ],
      "stages": [
        {
          "timer": 6, // TUNE
          "loops": 0,
          // TUNE: photomode pose lives under female/ — spike must confirm it plays on
          // male skeletons (same rig).
          "clips": [ { "file": "photomode/female/armscrossed_pose.af", "sec": 0.033 } ]
        }
      ]
    },
    // NOTE: the plan's relaxed_idlepartialbody_* prop idles (coffee, data slate) are
    // LAYER clips (~25 of 82 bones tracked) — standalone they T-pose the legs, so
    // they're replaced by full-body furniture chains. The coffee emote moved to
    // sit-lean.osf.json as the bar-lean drink variant (it needs a surface behind).
    {
      "id": "immersion/emote/dataslate",
      "name": "Data slate",
      "tags": [ "player.emote.dataslate", "immersion" ],
      "stages": [
        // Full-body standing dataslate chain: pull out the slate -> read -> put away.
        // Linear stages auto-advance (enter/exit play once; the read loops twice).
        {
          "clips": [ { "file": "furniture/standing_dataslate/enterfromstand.af", "sec": 4.033 } ]
        },
        {
          "loops": 2, // TUNE: ~4.7s of reading
          "clips": [ { "file": "furniture/standing_dataslate/idle.af", "sec": 2.367 } ]
        },
        { "clips": [ { "file": "furniture/standing_dataslate/exittostand.af", "sec": 4.367 } ] }
      ]
    }
    // Stretch (per Phase-0 spike results): boxer / jump / kneeling / cower from the
    // photomode/female/ pose set — add as player.emote.* scenes once confirmed.
  ]
}
