{
  "schema": 1,
  "name": "OSF Immersion — Emotes",
  // Solo self-terminating flourishes for the emote wheel (enumerated by tag prefix
  // "player.emote."). Each scene's `name` is the wheel slice label. Linear one-stage
  // form: `loops:0` holds the pose, `timer` ends it, and every linear stage gets a
  // free default advance edge so Space skips early. The same scenes play on a
  // crosshair NPC target (anonymous role, no gender filter).
  "clipRoot": "meshes/actors/human/animations",
  "stripActors": false,
  "lockPlayer": false, // short flourishes — leave the player's controls alone
  "camera": "none",    // never touch the camera for an emote
  // No `roles` block: each scene infers one anonymous slot from its single clip. The
  // role-less sheathe action targets the first participant — the player when launched
  // solo, or the crosshair NPC when the wheel targets one.
  "scenes": [
    {
      "id": "immersion/emote/wave",
      "name": "Wave",
      "tags": [ "player.emote.wave", "immersion" ],
      "stages": [
        {
          "timer": 4, // TUNE
          "loops": 0,
          "clips": [ { "file": "common/wave_pose.af", "sec": 0.033 } ],
          // Sheathe so the emote doesn't play around a drawn rifle; the ledger re-draws
          // on end. CAVEAT: the cleanup re-draw is unconditional, so an unarmed player
          // gets a draw call on end — TUNE: drop the action if that looks wrong.
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    },
    {
      "id": "immersion/emote/whatsup",
      "name": "What's up?",
      "tags": [ "player.emote.whatsup", "immersion" ],
      "stages": [
        {
          "timer": 4, // TUNE
          "loops": 0,
          "clips": [ { "file": "common/whatsup_pose.af", "sec": 0.033 } ],
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    },
    {
      "id": "immersion/emote/handsonhips",
      "name": "Hands on hips",
      "tags": [ "player.emote.handsonhips", "immersion" ],
      "stages": [
        {
          "timer": 5, // TUNE
          "loops": 0,
          "clips": [ { "file": "common/handsonhips_pose.af", "sec": 0.033 } ],
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    },
    {
      "id": "immersion/emote/armscrossed",
      "name": "Arms crossed",
      "tags": [ "player.emote.armscrossed", "immersion" ],
      "stages": [
        {
          "timer": 6, // TUNE
          "loops": 0,
          // TUNE: photomode pose lives under female/ — spike must confirm it plays on
          // male skeletons (same rig).
          "clips": [ { "file": "photomode/female/armscrossed_pose.af", "sec": 0.033 } ],
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    },
    {
      "id": "immersion/emote/coffee",
      "name": "Coffee break",
      "tags": [ "player.emote.coffee", "immersion" ],
      "stages": [
        {
          "loops": 2, // TUNE: ~8.8s total; spike must confirm the cup prop renders
          "clips": [ { "file": "common/relaxed_idlepartialbody_coffeecup.af", "sec": 4.4 } ],
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    },
    {
      "id": "immersion/emote/dataslate",
      "name": "Data slate",
      "tags": [ "player.emote.dataslate", "immersion" ],
      "stages": [
        {
          "loops": 2, // TUNE: ~8.8s total; spike must confirm the slate prop renders
          "clips": [ { "file": "common/relaxed_idlepartialbody_dataslate.af", "sec": 4.4 } ],
          "action": [ { "at": "enter", "type": "osf.weapon.sheathe" } ]
        }
      ]
    }
    // Stretch (per Phase-0 spike results): boxer / jump / kneeling / cower from the
    // photomode/female/ pose set — add as player.emote.* scenes once confirmed.
  ]
}
