{
  "schema": 1,
  "name": "OSF Immersion — Sit / Lean anywhere",
  // Solo hold-pose scenes driven by the toggleSceneTags hotkey verb
  // ("N": "toggleSceneTags:player.sit", "L": "toggleSceneTags:player.lean").
  // Space takes the default advance edge (stand up); re-pressing the hotkey ends the
  // scene too. Player lines up with walls/ground manually in v1 (no raycast snap).
  // lockPlayer stays default-true: you're seated/leaning; the director channel still
  // allows Space/End.
  "clipRoot": "meshes/actors/human/animations",
  "stripActors": false,
  "camera": "none", // per-scene thirdperson_hold below — no scene_orbit takeover
  // No `roles` block: each scene infers one anonymous slot from its single clip
  // (toggleSceneTags launches player-only, so 1-role is what makes these matchable).
  "scenes": [
    {
      "id": "immersion/sit/ground",
      "name": "Sit on ground",
      "tags": [ "player.sit", "immersion" ],
      "weight": 3, // TUNE: favour plain sitting over kneeling in the player.sit pool (3:1)
      "entry": "sit",
      "nodes": [
        {
          "id": "sit",
          "loops": 0, // hold forever — stand up via Space / hotkey re-press
          "stages": [
            // Hold pose — no sit-down/stand-up transition clips exist in vanilla, so
            // enter/exit is a blend, not an animation.
            { "clips": [ { "file": "common/sitonground_pose.af", "sec": 0.033 } ] }
          ],
          // TUNE: opening zoom 1.0 on the normalized [0..2] third-person axis
          "camera": [ { "at": "enter", "state": "thirdperson_hold", "distance": 1.0 } ],
          "edges": [
            { "id": "stand", "label": "Stand up", "to": "$end", "when": "advance", "default": true }
          ]
        }
      ]
    },
    // NOTE: the plan's gender-split variant (photomode/female/sitonground_pose.af as
    // immersion/sit/ground/f) is deliberately not shipped — add it only if the Phase-0
    // spike shows the male/female poses differ meaningfully.
    {
      "id": "immersion/kneel",
      "name": "Kneel",
      "tags": [ "player.sit", "immersion" ],
      "entry": "kneel",
      "nodes": [
        {
          "id": "kneel",
          "loops": 0,
          "stages": [
            // TUNE: photomode pose lives under female/ — spike must confirm it plays on
            // male skeletons (same rig) before gender-filtering the role.
            { "clips": [ { "file": "photomode/female/kneeling_pose.af", "sec": 0.033 } ] }
          ],
          "camera": [ { "at": "enter", "state": "thirdperson_hold", "distance": 1.0 } ], // TUNE
          "edges": [
            { "id": "stand", "label": "Stand up", "to": "$end", "when": "advance", "default": true }
          ]
        }
      ]
    },
    // Wall lean: the furniture/walllean* families are full-body clip CHAINS
    // (enterfromstand -> idle -> exittostand). Do NOT use common/leanright.af — it's a
    // partial cover-lean layer (tracks only a few bones; the untracked rest of the
    // skeleton falls back to bind pose = T-pose). Other ready-made families for later
    // variants: wallleanelbowleft/right, wallleanshoulderleft/right, raillean*.
    // Line your back up with a wall first; the actor leans where they stand.
    {
      "id": "immersion/lean/wall",
      "name": "Lean on wall",
      "tags": [ "player.lean", "immersion" ],
      "entry": "enter",
      "nodes": [
        {
          "id": "enter",
          // TUNE: the male enter is long (9.0s); if it drags, swap to enterinstant.af
          // (0.167s) or the female chain's 4.4s enterfromstand.
          "stages": [ { "clips": [ { "file": "furniture/wallleanback/enterfromstand.af", "sec": 9.033 } ] } ],
          "camera": [ { "at": "enter", "state": "thirdperson_hold", "distance": 1.0 } ], // TUNE
          "edges": [
            { "to": "hold", "when": "end" },
            { "id": "skip", "label": "Settle in", "to": "hold", "when": "advance", "default": true }
          ]
        },
        {
          "id": "hold",
          "loops": 0, // hold the lean until advanced
          "stages": [ { "clips": [ { "file": "furniture/wallleanback/idle.af", "sec": 2.333 } ] } ],
          "edges": [
            { "id": "stand", "label": "Push off", "to": "exit", "when": "advance", "default": true }
          ]
        },
        {
          "id": "exit",
          "stages": [ { "clips": [ { "file": "furniture/wallleanback/exittostand.af", "sec": 4.7 } ] } ],
          "edges": [ { "to": "$end", "when": "end" } ]
        }
      ]
    }
  ]
}
