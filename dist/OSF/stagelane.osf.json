{
  // Stage-level track lanes on a LINEAR scene. The cue/action/sound/camera lanes that used to
  // require the nodes[] graph form now ride directly on a `stages[]` entry — DesugarLinear forwards
  // each onto the stage's synthetic node, so this loads as a two-node chain (#s0 -> #s1 -> $end).
  // Two stages (each holds; manual AdvanceScene steps between them):
  //  - stage 0: camera posture + sound at enter + a clip-timed cue at fraction 0.5 (every loop).
  //  - stage 1: an osf.voice.play action at enter.
  "schema": 1,
  "id": "author.scenes.stagelane",
  "name": "Stage Lane Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "stages": [
    {
      "loops": 0,
      "clips": ["OSF/Animations/OSF_Test/TestSway01.glb"],
      "camera": [ { "at": "enter", "state": "thirdperson_hold" } ],
      "sound":  [ { "at": "enter", "spec": "OSF/Sounds/testbeep.wav", "role": "lead" } ],
      "cue":    [ { "at": 0.5, "repeat": "loop", "id": "beat" } ]
    },
    {
      "loops": 0,
      "clips": ["OSF/Animations/OSF_Test/StandCover01.glb"],
      "action": [ { "at": "enter", "type": "osf.voice.play", "role": "lead", "set": "OSF/Sounds/testbeep.wav" } ]
    }
  ]
}
