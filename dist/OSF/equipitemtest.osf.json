{
  // Arbitrary-item equip/remove test. One held node that, on enter, runs osf.equipment.equip on
  // the 'lead' role — equips the item named by `item` for the scene's duration, recording it in the
  // undo ledger. There is NO authored osf.equipment.unequip: on stop the ledger replays and takes
  // the item back off (and DESTROYS the copy if OSF added it, leaving no trace), proving cleanup
  // doesn't depend on an authored release (the symmetric pair, like equiptest/weapontest).
  //
  // `item` is a "<Plugin>|0xLOCAL" form ref (the local id's load-order byte is ignored, so a FormID
  // pasted whole from xEdit resolves regardless of its load-order prefix). EDIT IT to a real item on
  // your install before running — the example below is the vanilla "UC Antixeno Spacesuit"; if it
  // doesn't resolve the action warns and skips (nothing equipped, scene still plays).
  "schema": 1,
  "id": "author.scenes.equipitemtest",
  "name": "Equip Arbitrary Item Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "action": [
        { "at": "enter", "type": "osf.equipment.equip", "role": "lead", "item": "Starfield.esm|0x0021B937" }
      ]
    }
  ]
}
