{
  // Weapon sheathe/restore test. One held node that, on enter, runs osf.weapon.sheathe on the
  // 'lead' role — holsters the actor's weapon and records it in the undo ledger. There is NO
  // authored osf.weapon.restore: on StopScene the ledger replays and re-draws, proving cleanup
  // doesn't depend on an authored restore (the symmetric pair, like equiptest).
  //
  // Run it on an ARMED actor (draw your weapon first) — the sheathe is only meaningful when a
  // weapon is out, and restore re-draws unconditionally (author contract: sheathe armed roles).
  "schema": 2,
  "id": "author.scenes.weapontest",
  "name": "Weapon Sheathe/Restore Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "action": [
        { "at": "enter", "type": "osf.weapon.sheathe", "role": "lead" }
      ]
    }
  ]
}
