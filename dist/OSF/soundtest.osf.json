{
  // Sound lane + osf.voice.play test (Slice 16). One held node:
  //  - action osf.voice.play at enter (the 'set' spec is a Data-relative WAV);
  //  - sound lane: one at enter (lifecycle) + one at fraction 0.1 every loop (clip-timed).
  // All play OSF/Sounds/testbeep.wav through the miniaudio device, positioned at the lead.
  // Confirms the sound mechanism + that the sound lane rides the generalized timed-mark path.
  "schema": 2,
  "id": "author.scenes.soundtest",
  "name": "Sound Lane Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "action": [
        { "at": "enter", "type": "osf.voice.play", "role": "lead", "set": "OSF/Sounds/testbeep.wav" }
      ],
      "sound": [
        { "at": "enter", "spec": "OSF/Sounds/testbeep.wav", "role": "lead" },
        { "at": 0.1, "repeat": "loop", "spec": "OSF/Sounds/testbeep.wav", "role": "lead", "volume": 1.0 }
      ]
    }
  ]
}
