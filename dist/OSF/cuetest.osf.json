{
  // Cue-track test: one held node playing the 20s baked-in "solo" clip, decorated with a cue
  // track that fires EVENT_CUE at lifecycle anchors + clip fractions. With the 20s clip,
  // "at": 0.05 -> ~1s, "at": 0.1 -> ~2s, "end" -> ~20s. Watch the log for the CUE lines.
  "schema": 2,
  "id": "author.scenes.cuetest",
  "name": "Cue Track Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "cue": [
        { "at": "enter", "id": "began" },
        { "at": 0.05,    "id": "early" },
        { "at": 0.1, "repeat": "loop", "id": "tick" },
        { "at": "end",   "id": "looped" },
        { "at": "exit",  "id": "done" }
      ]
    }
  ]
}
