{
  // Fade + generalized undo-ledger test (Slice 14). One held node whose `action` track, on
  // enter, engages osf.control.lock THEN osf.fade.out — and authors NEITHER release. On any
  // termination the per-handle undo ledger replays in REVERSE record order: fade undo (fade
  // back in) BEFORE the control-lock release. Proves (a) osf.fade.out/in via the harvested
  // FadeService, (b) reversible-by-default fade (no authored fade.in needed), (c) ordered
  // reverse-replay across two mechanisms.
  "schema": 1,
  "id": "author.scenes.fadetest",
  "name": "Fade + Ledger Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "action": [
        { "at": "enter", "type": "osf.control.lock", "role": "lead" },
        { "at": "enter", "type": "osf.fade.out" }
      ]
    }
  ]
}
