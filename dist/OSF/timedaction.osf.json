{
  // Numeric-timed action test (Slice 13). One held node whose `action` track mixes the
  // lifecycle anchors (enter/exit, fired by Layer B directly) with a NUMERIC-timed action
  // ('test.tick' at clip fraction 0.3, every loop) — the new capability. A `cue` at 0.6
  // (every loop) rides the same generalized Scene timed-mark path, proving cues still fire
  // and that within a tick the action lane is decoded before the cue lane (§1.3 ordering;
  // here they fall on different fractions so order is just confirmed not to regress).
  "schema": 2,
  "id": "author.scenes.timedaction",
  "name": "Timed Action Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "main",
  "nodes": [
    {
      "id": "main",
      "use": "solo",
      "loop": { "mode": "hold" },
      "loopForever": true,
      "action": [
        { "at": "enter", "type": "test.begin" },
        { "at": 0.1, "repeat": "loop", "type": "test.tick" },
        { "at": "exit",  "type": "test.done" }
      ],
      "cue": [
        { "at": 0.1, "repeat": "loop", "id": "ping" }
      ]
    }
  ]
}
