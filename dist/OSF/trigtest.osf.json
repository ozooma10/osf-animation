{
  // Cue-trigger test: cues drive the graph with NO manual advance. Node 'first' (solo) fires
  // cue 'go' at clip fraction 0.1 (~2s into the 20s clip), whose trigger:go edge transitions
  // to 'second' (solo.cover); 'second' fires cue 'done' at 0.1, whose trigger:done edge ends
  // the scene ("$end"). Watch the log: CUE go -> cue-trigger -> 'second', CUE done -> $end.
  "schema": 2,
  "id": "author.scenes.trigtest",
  "name": "Cue Trigger Test",
  "tags": ["test", "solo"],
  "roles": [ { "name": "lead", "gender": "any" } ],
  "entry": "first",
  "nodes": [
    {
      "id": "first",
      "use": "solo",
      "loop": { "mode": "hold" },
      "cue": [ { "at": 0.1, "id": "go" } ],
      "edges": [ { "to": "second", "when": "trigger:go" } ]
    },
    {
      "id": "second",
      "use": "solo.cover",
      "loop": { "mode": "hold" },
      "cue": [ { "at": 0.1, "id": "done" } ],
      "edges": [ { "to": "$end", "when": "trigger:done" } ]
    }
  ]
}
