{
  "logLevel": "debug",
  "debugNotifications": true,
  // Global hotkeys: "KeyName": "command[:arg]" — see src/Config/Settings.h for the key-name set.
  // Commands: openBrowser | openWheel[:tagPrefix] | toggleSceneTags:<tag[,tag..]>.
  // Director-channel keys (Space, P, End, 0, +, -, E) are refused; bound keys are not consumed.
  // NOTE: toggleSceneTags launches with the player as the SOLE actor, so it only matches
  // 1-role scenes. player.sit / player.lean live in dist/OSF/immersion/sit-lean.osf.json.
  "hotkeys": {
    "B": "openBrowser",
    "G": "openWheel",
    "N": "toggleSceneTags:player.sit",
    "semicolon": "toggleSceneTags:player.lean"
  }
}
